{
    "name": "s2id-backend",
    "version": "1.0.0",
    "description": "Backend para coleta automatizada de dados S2ID e Atlas Digital",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "collect:atlas": "tsx src/scripts/collectAtlas.ts",
        "collect:s2id": "tsx src/scripts/collectS2ID.ts",
        "collect:all": "tsx src/scripts/collectAll.ts",
        "import:s2id": "tsx src/scripts/importS2IDCSV.ts"
    },
    "dependencies": {
        "axios": "^1.6.0",
        "cors": "^2.8.5",
        "csv-parse": "^5.5.2",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "node-cron": "^3.0.3",
        "puppeteer": "^23.0.0",
        "socket.io": "^4.7.2",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "@types/node-cron": "^3.0.11",
        "tsx": "^4.6.2",
        "typescript": "^5.3.2"
    }
}