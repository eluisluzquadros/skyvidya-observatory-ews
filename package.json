{
  "name": "s2id-disaster-monitor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n FE,BE,PY -c cyan,green,yellow \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:analytics\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch server.ts",
    "dev:analytics": "cd analytics && python -m uvicorn main:app --reload --port 8000",
    "dev:all": "concurrently -n FE,BE,PY -c cyan,green,yellow \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:analytics\"",
    "build": "vite build",
    "preview": "vite preview",
    "pipeline": "cd analytics && python scripts/run_pipeline.py",
    "pipeline:download": "cd analytics && python scripts/download_ibge.py",
    "import:s2id": "tsx server/src/scripts/importS2IDCSV.ts",
    "stack:up": "cd pipeline && docker-compose up -d",
    "stack:down": "cd pipeline && docker-compose down",
    "stack:logs": "cd pipeline && docker-compose logs -f kestra",
    "pipeline:verify": "python pipeline/scripts/verify_setup.py",
    "bronze:ingest": "python pipeline/scripts/bronze_ingest.py",
    "dbt:run": "cd pipeline/dbt && dbt deps && dbt run",
    "dbt:test": "cd pipeline/dbt && dbt test",
    "dbt:silver": "cd pipeline/dbt && dbt run --select silver",
    "dbt:gold": "cd pipeline/dbt && dbt run --select gold",
    "dbt:spatial": "cd pipeline/dbt && dbt run --select mart_disasters_geo",
    "geo:export": "python pipeline/scripts/export_gold_geojson.py",
    "medallion": "python pipeline/scripts/run_medallion.py",
    "pipeline:full": "npm run bronze:ingest && npm run medallion && npm run geo:export",
    "pipeline:dbt": "npm run bronze:ingest && npm run dbt:run && npm run geo:export"
  },
  "dependencies": {
    "@google/genai": "^1.32.0",
    "duckdb": "^1.1.3",
    "@tailwindcss/typography": "^0.5.19",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "d3": "^7.9.0",
    "daisyui": "^5.5.19",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "lucide-react": "^0.556.0",
    "node-cron": "^4.2.1",
    "puppeteer": "^24.37.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.5.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.19.15",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
