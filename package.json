{
  "name": "s2id-disaster-monitor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch server/src/index.ts",
    "dev:analytics": "cd analytics && uvicorn main:app --reload --port 8000",
    "dev:all": "concurrently -n FE,BE,PY -c cyan,green,yellow \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:analytics\"",
    "build": "vite build",
    "preview": "vite preview",
    "pipeline": "cd analytics && python scripts/run_pipeline.py",
    "pipeline:download": "cd analytics && python scripts/download_ibge.py"
  },
  "dependencies": {
    "@google/genai": "^1.32.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^5.0.6",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "daisyui": "^5.5.19",
    "express": "^5.2.1",
    "lucide-react": "^0.556.0",
    "puppeteer": "^24.37.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.5.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
