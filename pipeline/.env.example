# pipeline/.env — copie para pipeline/.env e ajuste os caminhos absolutos
# Necessário apenas para as tasks dbt do Kestra (docker.volumes)

# Caminho absoluto para server/data no HOST (onde o DuckDB ews.duckdb vive)
HOST_EWS_DATA=/absolute/path/to/s2id-disaster-monitor/server/data

# Caminho absoluto para pipeline/dbt no HOST (projeto dbt com models e profiles)
HOST_EWS_DBT=/absolute/path/to/s2id-disaster-monitor/pipeline/dbt
